{
  "manifest_version": 3,
  "name": "Threads Unfollowers Tracker",
  "version": "1.0.0",
  "description": "Cek dan download akun yang tidak follback di Threads.",
  "content_scripts": [
    {
      "matches": ["*://*.threads.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.threads.com/*"]
    }
  ]
}